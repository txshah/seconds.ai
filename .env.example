# --- ClickHouse ---------------------------------------------------------------
# Local clickhouse-server defaults (works out of the box with `make db`):
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false
CLICKHOUSE_DATABASE=seconds
#
# For ClickHouse Cloud, change to (nothing else in the code changes):
#   CLICKHOUSE_HOST=<service>.<region>.clickhouse.cloud
#   CLICKHOUSE_PORT=8443
#   CLICKHOUSE_USER=default
#   CLICKHOUSE_PASSWORD=<your-password>
#   CLICKHOUSE_SECURE=true

# --- Reddit ingestion ---------------------------------------------------------
REDDIT_SUBREDDITS=legaladvice,consumer,personalfinance,mildlyinfuriating,scams,creditcards,smallbusiness
REDDIT_LISTING=new
REDDIT_LIMIT=50
# REDDIT_USER_AGENT=seconds.ai/0.1 (consumer-lawsuit-intel)

# --- Firecrawl (Guild.ai acquisition path) ------------------------------------
# Set this to run the Firecrawl source locally (`make firecrawl`) or on Render.
FIRECRAWL_API_KEY=
FIRECRAWL_LIMIT=5
# ';'-separated search queries (they contain commas, so not comma-separated):
# FIRECRAWL_QUERIES=site:reddit.com overcharged hidden fee;data breach lawsuit 2026

# --- Pipeline -----------------------------------------------------------------
# Store every lead (Pioneer decides the real cutoff). Raise to pre-filter noise.
SIGNAL_FLOOR=0.0

# --- API ----------------------------------------------------------------------
# Optional shared secret; if set, POST /ingest/run requires X-Ingest-Token.
API_INGEST_TOKEN=
